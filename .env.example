# ==============================================
# AI API 配置
# ==============================================

# 方式 1：直接使用 Coze Personal Access Token (PAT)
# 优点：简单，适合个人开发快速测试
# 缺点：有效期短，需要手动刷新
# 获取：https://www.coze.cn/open/oauth/pats
# COZE_TOKEN=pat_xxx

# 方式 2：Coze OAuth JWT 认证（推荐用于生产环境）
# 优点：自动续期，安全性更高，适合长期部署
# 如何获取：
#   1. 进入 Coze 控制台 "应用" 页面
#   2. 创建 JWT 应用，获取 Client ID 和 KID
#   3. 下载私钥文件（.pem），不要把私钥内容直接写进 .env！
#
# 最简配置（推荐）：
#   - 把 .pem 文件放在项目目录：./secrets/coze_private_key.pem
#   - 只需要填下面三个参数
#
COZE_OAUTH_CLIENT_ID=你的ClientID
COZE_OAUTH_KID=你的KID
COZE_OAUTH_PRIVATE_KEY_PATH=/app/secrets/coze_private_key.pem

# （不推荐）如果不想挂载文件，也可以用内联私钥
# 注意：需要把换行符替换成 \n，例如 "-----BEGIN RSA PRIVATE KEY-----\n...\n...\n-----END RSA PRIVATE KEY-----"
# COZE_OAUTH_PRIVATE_KEY=你的私钥内容

# Coze Workflow ID
# 在 Coze 工作流编辑页面，从浏览器地址栏或发布页面获取
COZE_WORKFLOW_ID=你的workflow_id

# Coze API 域名（国内用 .cn，海外用 .com）
COZE_BASE_URL=https://api.coze.cn

# ==============================================
# 服务端口
# ==============================================

WORDS_APP_PORT=8080

# ==============================================
# 用户系统（可选，保留默认值即可）
# ==============================================

# 默认单词本用户 ID，未登录时使用
# 如果是个人部署，建议改成自己的固定 ID，比如你的邮箱或者用户名
DEFAULT_WORDS_USER_ID=demo-user
VITE_WORDS_USER_ID=demo-user

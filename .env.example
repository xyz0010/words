# Coze API Configuration
COZE_TOKEN=your_coze_token_here
COZE_WORKFLOW_ID=your_workflow_id_here
COZE_BASE_URL=https://api.coze.cn

# Coze OAuth JWT Configuration (Recommended for auto-renew)
COZE_OAUTH_CLIENT_ID=
COZE_OAUTH_KID=
COZE_OAUTH_PRIVATE_KEY=
# Or use a file path mounted into the container
COZE_OAUTH_PRIVATE_KEY_PATH=
COZE_OAUTH_AUDIENCE=
COZE_OAUTH_TOKEN_TTL=3600

# Youdao API Configuration (Optional)
YOUDAO_APP_KEY=
YOUDAO_APP_SECRET=

# Wordbook API Configuration
DEFAULT_WORDS_USER_ID=demo-user
WORDS_DATA_DIR=./data
VITE_WORDS_USER_ID=demo-user
VITE_WORDS_API_BASE=

# Optional auth bootstrap
VITE_ENABLE_AUTH=true
